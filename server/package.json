{
  "name": "dnd-health-tracker-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Server-side D&D Beyond HP tracker: polls/subscribes to characters and publishes a tiny precomputed file per character for the Pico 2 W LED bars.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@fastify/formbody": "^8.0.2",
    "better-sqlite3": "^11.8.1",
    "fastify": "^5.2.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.0",
    "@types/ws": "^8.5.14",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
